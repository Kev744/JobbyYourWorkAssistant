{
  "name": "matchingcv-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": "20.19.0",
    "pnpm": "10.11.0"
  },
  "scripts": {
    "dev": "next dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "prisma generate",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "jest",
    "db:generate": "prisma generate",
    "db:reset": "prisma migrate reset",
    "db:init": "node scripts/init-db.mjs",
    "db:migrate-dev": "prisma migrate dev",
    "db:migrate-prod": "prisma migrate deploy",
    "build": "next build",
    "start": "next start",
    "automation:test": "playwright test",
    "automation:headed": "playwright test --headed",
    "automation:report": "playwright show-report",
    "automation:install-browsers": "playwright install chromium",
    "automation:helper": "node scripts/auto-apply-helper.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "jose": "^6.0.12",
    "next": "^16.2.2",
    "pdfkit": "^0.18.0",
    "pg": "^8.22.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.30",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.25.0",
    "eslint-config-next": "^16.2.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "playwright": "^1.61.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3"
  }
}
